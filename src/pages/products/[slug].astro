---
import FinalCta from "@components/FinalCta.astro";
import DetailStickyCta from "@components/DetailStickyCta.astro";
import SiteFooter from "@components/SiteFooter.astro";
import SiteHeader from "@components/SiteHeader.astro";
import SiteInteractions from "@components/SiteInteractions.astro";
import { products, siteMeta } from "@data/site";
import BaseLayout from "@layouts/BaseLayout.astro";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;
---

<BaseLayout
  title={`${product.name} - Hi Series`}
  description={product.description}
  image={siteMeta.image}
  canonical={new URL(`/products/${product.slug}`, Astro.site || Astro.url).href}
>
  <SiteHeader />
  <main id="main">
    <section class={`detail-hero ${product.tone}`}>
      <div class="detail-copy reveal">
        <span class="section-label">{product.label}</span>
        <h1>{product.name}</h1>
        <p>{product.headline}</p>
        <div class="hero-actions">
          <a class="button primary magnetic" href={product.productUrl} target="_blank" rel="noreferrer">进入 {product.name}</a>
          <a class="button secondary magnetic" href="#pricing">查看价格</a>
          <a class="button secondary magnetic" href="/#products">返回产品线</a>
        </div>
      </div>
      <div class="detail-panel tilt-card reveal">
        <span>{product.audience}</span>
        <h2>{product.status}</h2>
        <p>{product.description}</p>
        <div class="detail-metrics">
          {
            product.metrics.map((metric) => (
              <div>
                <strong>{metric.value}</strong>
                <span>{metric.label}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section fit-section">
      <div class="fit-card reveal">
        <span class="section-label">Best for</span>
        <h2>适合这些使用者</h2>
        <ul>
          {product.bestFor.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="fit-card muted reveal">
        <span class="section-label">Not ideal for</span>
        <h2>暂时不优先覆盖</h2>
        <ul>
          {product.notFor.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    <section class="section detail-section">
      <div class="section-heading reveal">
        <span class="section-label">Highlights</span>
        <h2>核心能力</h2>
      </div>
      <div class="feature-grid">
        {
          product.features.map((feature, index) => (
            <article class="feature-card reveal">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <p>{feature}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section scenario-section">
      <div class="section-heading reveal">
        <span class="section-label">Scenarios</span>
        <h2>典型使用场景</h2>
        <p>产品页不只列功能，也说明它在真实工作中应该放在哪个位置。</p>
      </div>
      <div class="scenario-grid">
        {
          product.scenarios.map((scenario, index) => (
            <article class="scenario-card reveal">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{scenario.title}</h3>
              <p>{scenario.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section detail-section compact">
      <div class="section-heading reveal">
        <span class="section-label">Workflow</span>
        <h2>使用流程</h2>
      </div>
      <div class="workflow">
        {
          product.workflow.map((step, index) => (
            <div class="workflow-step reveal">
              <span>{index + 1}</span>
              <strong>{step}</strong>
            </div>
          ))
        }
      </div>
    </section>

    <section class="section pricing detail-pricing" id="pricing">
      <div class="section-heading reveal">
        <span class="section-label">Pricing</span>
        <h2>价格与开通方式</h2>
      </div>
      <div class="pricing-grid">
        {
          product.pricing.map((plan) => (
            <article class={`pricing-card ${product.tone} reveal`}>
              <span>{product.name}</span>
              <h3>{plan.name}</h3>
              <strong>{plan.price}</strong>
              <p>{plan.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section faq">
      <div class="section-heading reveal">
        <span class="section-label">FAQ</span>
        <h2>常见问题</h2>
      </div>
      <div class="faq-list">
        {
          product.faq.map((item) => (
            <details class="faq-item reveal">
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))
        }
      </div>
    </section>

    <FinalCta href="/#products" label="查看全部产品" />
  </main>
  <DetailStickyCta productName={product.name} productUrl={product.productUrl} />
  <SiteFooter />
  <SiteInteractions />
</BaseLayout>

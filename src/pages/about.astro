---
import AuthorSection from "@components/AuthorSection.astro";
import FinalCta from "@components/FinalCta.astro";
import PageHero from "@components/PageHero.astro";
import SiteFooter from "@components/SiteFooter.astro";
import SiteHeader from "@components/SiteHeader.astro";
import SiteInteractions from "@components/SiteInteractions.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="关于作者 - Hi Series" description="了解 Hi Series 的作者、产品动机和联系方式。">
  <SiteHeader />
  <main id="main">
    <PageHero
      eyebrow="About"
      title="Hi Series 来自持续构建 AI 产品的实践。"
      description="作者页负责讲清楚产品背后的判断：为什么从 API 中转和图片生成开始，以及后续会怎样把它扩展成完整工具矩阵。"
    />
    <AuthorSection />
    <FinalCta href="/#products" label="查看产品" />
  </main>
  <SiteFooter />
  <SiteInteractions />
</BaseLayout>

---
import { products } from "@data/site";
---

<section class="hero">
  <div class="hero-copy reveal">
    <p class="eyebrow">Hi 开头的一组 AI 产品</p>
    <h1>把 AI 能力整理成清爽、可靠、能马上用的工具。</h1>
    <p class="hero-lede">
      Hi Series 目前包含 HI API 中转站与 Hi AI Image Studio。一个服务开发者稳定接入模型，
      一个服务创作者快速生成图片，后续会继续扩展成更完整的 AI 工具矩阵。
    </p>
    <div class="hero-actions">
      <a class="button primary" href="#products">浏览产品</a>
      <a class="button secondary" href="#author">了解作者</a>
    </div>
  </div>

  <div class="hero-stage reveal interactive-stage" aria-label="Hi Series 产品概览">
    <div class="cursor-light" aria-hidden="true"></div>
    {
      products.map((product) => (
        <div class={`orbit-card tilt-card card-${product.tone}`}>
          <span class="product-kicker">{product.audience}</span>
          <strong>{product.name}</strong>
          <p>{product.description}</p>
        </div>
      ))
    }
    <div class="signal-panel">
      <span>Series status</span>
      <strong>{products.length.toString().padStart(2, "0")}</strong>
      <small>products live</small>
    </div>
  </div>
</section>
